<ResourceDictionary
    xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- LIGHT PALETTE -->
    <Color x:Key="BgDeepColor">#FFF5F6F8</Color>
    <Color x:Key="BgPanelColor">#FFFFFFFF</Color>
    <Color x:Key="BgPanelHoverColor">#FFEEF1F6</Color>
    <Color x:Key="BorderColor">#FFE1E4EB</Color>
    <Color x:Key="BorderStrongColor">#FFC9CFDA</Color>
    <Color x:Key="TextColor">#FF1B1F2A</Color>
    <Color x:Key="TextMutedColor">#FF6B7180</Color>
    <Color x:Key="AccentColor">#FF2F6BE0</Color>
    <Color x:Key="AccentHoverColor">#FF447CEC</Color>
    <Color x:Key="AccentPressColor">#FF1F58C8</Color>
    <Color x:Key="DangerColor">#FFD5304B</Color>
    <Color x:Key="SuccessColor">#FF1F9D5E</Color>
    <Color x:Key="PreviewPageColor">#FFFFFFFF</Color>
    <Color x:Key="PreviewUsableColor">#FFF1F4FA</Color>
    <Color x:Key="PreviewCellColor">#552F6BE0</Color>
    <Color x:Key="PreviewCellBorderColor">#FF2F6BE0</Color>
    <Color x:Key="PreviewCutMarkColor">#FFD5304B</Color>

    <SolidColorBrush x:Key="BgDeep" Color="{StaticResource BgDeepColor}"/>
    <SolidColorBrush x:Key="BgPanel" Color="{StaticResource BgPanelColor}"/>
    <SolidColorBrush x:Key="BgPanelHover" Color="{StaticResource BgPanelHoverColor}"/>
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}"/>
    <SolidColorBrush x:Key="BorderStrongBrush" Color="{StaticResource BorderStrongColor}"/>
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}"/>
    <SolidColorBrush x:Key="TextMutedBrush" Color="{StaticResource TextMutedColor}"/>
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}"/>
    <SolidColorBrush x:Key="AccentHoverBrush" Color="{StaticResource AccentHoverColor}"/>
    <SolidColorBrush x:Key="AccentPressBrush" Color="{StaticResource AccentPressColor}"/>
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}"/>
    <SolidColorBrush x:Key="SuccessBrush" Color="{StaticResource SuccessColor}"/>
    <SolidColorBrush x:Key="PreviewPageBrush" Color="{StaticResource PreviewPageColor}"/>
    <SolidColorBrush x:Key="PreviewUsableBrush" Color="{StaticResource PreviewUsableColor}"/>
    <SolidColorBrush x:Key="PreviewCellBrush" Color="{StaticResource PreviewCellColor}"/>
    <SolidColorBrush x:Key="PreviewCellBorderBrush" Color="{StaticResource PreviewCellBorderColor}"/>
    <SolidColorBrush x:Key="PreviewCutMarkBrush" Color="{StaticResource PreviewCutMarkColor}"/>
</ResourceDictionary>
