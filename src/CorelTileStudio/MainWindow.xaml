<Window x:Class="CorelTileStudio.MainWindow"
        x:Name="Self"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:vm="clr-namespace:CorelTileStudio.ViewModels"
        xmlns:cnv="clr-namespace:CorelTileStudio.Converters"
        xmlns:svc="clr-namespace:CorelTileStudio.Services"
        xmlns:ctl="clr-namespace:CorelTileStudio.Controls"
        Title="CorelTile Studio"
        Width="900" Height="780"
        MinWidth="780" MinHeight="600"
        WindowStartupLocation="Manual"
        Left="60" Top="60"
        WindowStyle="None"
        AllowsTransparency="True"
        Background="Transparent"
        ResizeMode="CanResize"
        ShowInTaskbar="True"
        Topmost="True"
        FontFamily="Segoe UI">

    <Window.DataContext>
        <vm:MainViewModel/>
    </Window.DataContext>

    <Window.Resources>
        <BooleanToVisibilityConverter x:Key="BoolToVis"/>
        <cnv:InverseBooleanConverter x:Key="InvBool"/>
    </Window.Resources>

    <Border Background="{DynamicResource BgDeep}"
            BorderBrush="{DynamicResource BorderStrongBrush}"
            BorderThickness="1"
            CornerRadius="10">
        <Border.Effect>
            <DropShadowEffect BlurRadius="22" ShadowDepth="0" Opacity="0.55" Color="Black"/>
        </Border.Effect>

        <Grid>
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <!-- ============ TITLE BAR ============ -->
            <Border Grid.Row="0" Height="44"
                    Background="{DynamicResource BgPanel}"
                    CornerRadius="10,10,0,0"
                    MouseLeftButtonDown="TitleBar_MouseLeftButtonDown"
                    BorderBrush="{DynamicResource BorderBrush}"
                    BorderThickness="0,0,0,1">
                <Grid>
                    <StackPanel Orientation="Horizontal" Margin="14,0" VerticalAlignment="Center">
                        <Border Width="22" Height="22" CornerRadius="5" Background="{DynamicResource AccentBrush}"
                                VerticalAlignment="Center">
                            <TextBlock Text="C" Foreground="White" FontWeight="Bold"
                                       HorizontalAlignment="Center" VerticalAlignment="Center"/>
                        </Border>
                        <TextBlock Text="{Binding Source={x:Static svc:Localization.Instance}, Path=AppTitle}"
                                   Foreground="{DynamicResource TextBrush}"
                                   FontWeight="Bold" FontSize="13" VerticalAlignment="Center" Margin="10,0,0,0"/>
                        <TextBlock Foreground="{DynamicResource TextMutedBrush}" FontSize="11"
                                   VerticalAlignment="Center" Margin="8,1,0,0">
                            <Run Text="·  "/>
                            <Run Text="{Binding Source={x:Static svc:Localization.Instance}, Path=AppSubtitle}"/>
                        </TextBlock>
                    </StackPanel>

                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,8,0">
                        <Button Style="{StaticResource ChromeButton}"
                                Command="{Binding ToggleLanguageCommand}"
                                Content="{Binding LanguageGlyph}"
                                ToolTip="{Binding Source={x:Static svc:Localization.Instance}, Path=LanguageTooltip}"
                                FontWeight="Bold"/>
                        <Button Style="{StaticResource ChromeButton}"
                                Command="{Binding ToggleThemeCommand}"
                                Content="◑"
                                ToolTip="{Binding Source={x:Static svc:Localization.Instance}, Path=ThemeTooltip}"/>
                        <ToggleButton x:Name="PinButton"
                                      Width="34" Height="28" Cursor="Hand"
                                      IsChecked="{Binding Topmost, RelativeSource={RelativeSource AncestorType=Window}, Mode=TwoWay}"
                                      ToolTip="{Binding Source={x:Static svc:Localization.Instance}, Path=PinTooltip}">
                            <ToggleButton.Template>
                                <ControlTemplate TargetType="ToggleButton">
                                    <Border x:Name="Bd" Background="Transparent" CornerRadius="3">
                                        <TextBlock Text="📌" FontSize="13" HorizontalAlignment="Center"
                                                   VerticalAlignment="Center" Foreground="{DynamicResource TextMutedBrush}"
                                                   x:Name="Icon"/>
                                    </Border>
                                    <ControlTemplate.Triggers>
                                        <Trigger Property="IsMouseOver" Value="True">
                                            <Setter TargetName="Bd" Property="Background" Value="{DynamicResource BgPanelHover}"/>
                                        </Trigger>
                                        <Trigger Property="IsChecked" Value="True">
                                            <Setter TargetName="Icon" Property="Foreground" Value="{DynamicResource AccentBrush}"/>
                                        </Trigger>
                                    </ControlTemplate.Triggers>
                                </ControlTemplate>
                            </ToggleButton.Template>
                        </ToggleButton>
                        <Button Style="{StaticResource ChromeButton}" Click="MinimizeButton_Click" Content="—"
                                ToolTip="{Binding Source={x:Static svc:Localization.Instance}, Path=MinimizeTooltip}"/>
                        <Button Style="{StaticResource ChromeCloseButton}" Click="CloseButton_Click" Content="✕"
                                ToolTip="{Binding Source={x:Static svc:Localization.Instance}, Path=CloseTooltip}"/>
                    </StackPanel>
                </Grid>
            </Border>

            <!-- ============ MAIN CONTENT (2 columns) ============ -->
            <Grid Grid.Row="1">
                <Grid.ColumnDefinitions>
                    <ColumnDefinition Width="400"/>
                    <ColumnDefinition Width="*"/>
                </Grid.ColumnDefinitions>

                <!-- ============ LEFT: CONTROLS ============ -->
                <ScrollViewer Grid.Column="0" VerticalScrollBarVisibility="Auto" Padding="14,14,8,4">
                    <StackPanel>

                        <!-- Conexion -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <Grid>
                                    <TextBlock Style="{StaticResource SectionTitle}"
                                               Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecConnection}"/>
                                    <Ellipse Width="9" Height="9" HorizontalAlignment="Right" VerticalAlignment="Top"
                                             Margin="0,4,0,0">
                                        <Ellipse.Style>
                                            <Style TargetType="Ellipse">
                                                <Setter Property="Fill" Value="{DynamicResource DangerBrush}"/>
                                                <Style.Triggers>
                                                    <DataTrigger Binding="{Binding IsConnected}" Value="True">
                                                        <Setter Property="Fill" Value="{DynamicResource SuccessBrush}"/>
                                                    </DataTrigger>
                                                </Style.Triggers>
                                            </Style>
                                        </Ellipse.Style>
                                    </Ellipse>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="Auto"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel>
                                        <TextBlock Foreground="{DynamicResource TextBrush}" FontSize="12">
                                            <Run Text="CorelDRAW "/>
                                            <Run Text="{Binding CorelVersion}" FontWeight="SemiBold"/>
                                        </TextBlock>
                                        <TextBlock Text="{Binding SelectionInfo}" Style="{StaticResource HintText}" Margin="0,2,0,0"/>
                                    </StackPanel>
                                    <Button Grid.Column="1" Style="{StaticResource GhostButton}"
                                            Command="{Binding ConnectCommand}"
                                            Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnConnect}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Objeto -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecObject}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:Localization.Instance}, Path=HintObject}"
                                           Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblWidthCm}"/>
                                        <TextBox Text="{Binding ObjectWidthCm, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblHeightCm}"/>
                                        <TextBox Text="{Binding ObjectHeightCm, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <Button Margin="0,10,0,0" Style="{StaticResource GhostButton}"
                                        Command="{Binding ReadSelectionCommand}" HorizontalAlignment="Stretch"
                                        Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnReadSelection}"/>
                                <Button Margin="0,6,0,0" Style="{StaticResource GhostButton}"
                                        Command="{Binding AutoDetectCommand}" HorizontalAlignment="Stretch"
                                        Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnAutoDetect}"/>
                            </StackPanel>
                        </Border>

                        <!-- Area -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecArea}"/>
                                <TextBlock Text="{Binding Source={x:Static svc:Localization.Instance}, Path=HintArea}"
                                           Style="{StaticResource HintText}" TextWrapping="Wrap" Margin="0,0,0,8"/>
                                <CheckBox Content="{Binding Source={x:Static svc:Localization.Instance}, Path=ChkUseCorelPage}"
                                          IsChecked="{Binding UseCorelPage}" Margin="0,0,0,10"/>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblWidthCm}"/>
                                        <TextBox Text="{Binding AreaWidthCm, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblHeightCm}"/>
                                        <TextBox Text="{Binding AreaHeightCm, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                                            Command="{Binding ReadPageCommand}"
                                            Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnReadPage}"/>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                            Command="{Binding ReadRectangleCommand}"
                                            Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnReadRectangle}"/>
                                </Grid>
                                <TextBlock Margin="0,8,0,0" Style="{StaticResource HintText}">
                                    <Run Text="Origen: "/>
                                    <Run Text="{Binding AreaSourceLabel}" FontWeight="SemiBold"/>
                                </TextBlock>
                            </StackPanel>
                        </Border>

                        <!-- Margenes / Espaciado -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecMargins}"/>
                                <Grid Margin="0,0,0,8">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblLeft}"/>
                                        <TextBox Text="{Binding MarginLeftCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblRight}"/>
                                        <TextBox Text="{Binding MarginRightCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="4">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblTop}"/>
                                        <TextBox Text="{Binding MarginTopCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="6">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblBottom}"/>
                                        <TextBox Text="{Binding MarginBottomCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <Grid>
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblSpacingX}"/>
                                        <TextBox Text="{Binding SpacingXCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblSpacingY}"/>
                                        <TextBox Text="{Binding SpacingYCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Layout -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecLayout}"/>
                                <CheckBox Content="{Binding Source={x:Static svc:Localization.Instance}, Path=ChkAutoFit}"
                                          IsChecked="{Binding AutoFit}" Margin="0,0,0,8"/>
                                <Grid IsEnabled="{Binding AutoFit, Converter={StaticResource InvBool}}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblColumns}"/>
                                        <TextBox Text="{Binding Columns, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblRows}"/>
                                        <TextBox Text="{Binding Rows, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                                <CheckBox Content="{Binding Source={x:Static svc:Localization.Instance}, Path=ChkCenter}"
                                          IsChecked="{Binding CenterInArea}" Margin="0,10,0,0"/>
                            </StackPanel>
                        </Border>

                        <!-- Cut marks -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecCutMarks}"/>
                                <CheckBox Content="{Binding Source={x:Static svc:Localization.Instance}, Path=ChkCutMarks}"
                                          IsChecked="{Binding CutMarks}" Margin="0,0,0,8"/>
                                <Grid IsEnabled="{Binding CutMarks}">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="10"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <StackPanel Grid.Column="0">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblCutLength}"/>
                                        <TextBox Text="{Binding CutMarkLengthCm, StringFormat={}{0:0.##}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                    <StackPanel Grid.Column="2">
                                        <TextBlock Style="{StaticResource LabelText}"
                                                   Text="{Binding Source={x:Static svc:Localization.Instance}, Path=LblCutWeight}"/>
                                        <TextBox Text="{Binding CutMarkWeightMm, StringFormat={}{0:0.###}, UpdateSourceTrigger=PropertyChanged}"/>
                                    </StackPanel>
                                </Grid>
                            </StackPanel>
                        </Border>

                        <!-- Presets -->
                        <Border Style="{StaticResource Card}">
                            <StackPanel>
                                <TextBlock Style="{StaticResource SectionTitle}"
                                           Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecPresets}"/>
                                <ComboBox ItemsSource="{Binding Presets}"
                                          SelectedItem="{Binding SelectedPreset}"
                                          DisplayMemberPath="Name"/>
                                <Grid Margin="0,8,0,0">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="*"/>
                                        <ColumnDefinition Width="6"/>
                                        <ColumnDefinition Width="*"/>
                                    </Grid.ColumnDefinitions>
                                    <Button Grid.Column="0" Style="{StaticResource GhostButton}"
                                            Command="{Binding SavePresetCommand}"
                                            Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnSavePreset}"/>
                                    <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                            Command="{Binding DeletePresetCommand}"
                                            Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnDeletePreset}"/>
                                </Grid>
                            </StackPanel>
                        </Border>

                    </StackPanel>
                </ScrollViewer>

                <!-- ============ RIGHT: PREVIEW + ACTIONS ============ -->
                <Grid Grid.Column="1" Margin="6,14,14,4">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>

                    <TextBlock Grid.Row="0" Style="{StaticResource SectionTitle}"
                               Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecPreview}"/>

                    <Border Grid.Row="1" Background="{DynamicResource BgPanel}"
                            BorderBrush="{DynamicResource BorderBrush}" BorderThickness="1"
                            CornerRadius="6" Margin="0,0,0,10">
                        <ctl:GridPreview
                            AreaWidthCm="{Binding AreaWidthCm}"
                            AreaHeightCm="{Binding AreaHeightCm}"
                            MarginLeftCm="{Binding MarginLeftCm}"
                            MarginRightCm="{Binding MarginRightCm}"
                            MarginTopCm="{Binding MarginTopCm}"
                            MarginBottomCm="{Binding MarginBottomCm}"
                            ObjectWidthCm="{Binding ObjectWidthCm}"
                            ObjectHeightCm="{Binding ObjectHeightCm}"
                            SpacingXCm="{Binding SpacingXCm}"
                            SpacingYCm="{Binding SpacingYCm}"
                            Columns="{Binding Columns}"
                            Rows="{Binding Rows}"
                            CenterInArea="{Binding CenterInArea}"
                            CutMarks="{Binding CutMarks}"
                            CutMarkLengthCm="{Binding CutMarkLengthCm}"/>
                    </Border>

                    <Border Grid.Row="2" Style="{StaticResource Card}" Margin="0,0,0,10">
                        <StackPanel>
                            <TextBlock Style="{StaticResource SectionTitle}"
                                       Text="{Binding Source={x:Static svc:Localization.Instance}, Path=SecPlan}"/>
                            <TextBlock Text="{Binding PlanSummary}" Foreground="{DynamicResource TextBrush}"
                                       FontSize="12" TextWrapping="Wrap"/>
                            <Border Visibility="{Binding HasWarning, Converter={StaticResource BoolToVis}}"
                                    Background="#22E2516C" BorderBrush="{DynamicResource DangerBrush}"
                                    BorderThickness="1" CornerRadius="4" Padding="8,6" Margin="0,8,0,0">
                                <TextBlock Text="{Binding PlanWarning}" Foreground="{DynamicResource DangerBrush}"
                                           FontSize="11" TextWrapping="Wrap"/>
                            </Border>
                        </StackPanel>
                    </Border>

                    <Grid Grid.Row="3">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="10"/>
                            <ColumnDefinition Width="Auto"/>
                        </Grid.ColumnDefinitions>
                        <Button Grid.Column="0" Style="{StaticResource PrimaryButton}"
                                Command="{Binding ApplyTileCommand}" Padding="12,12"
                                FontSize="13"
                                Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnApplyTile}"/>
                        <Button Grid.Column="2" Style="{StaticResource GhostButton}"
                                Command="{Binding PrintCommand}" Padding="14,12" FontSize="13"
                                Content="{Binding Source={x:Static svc:Localization.Instance}, Path=BtnPrint}"/>
                    </Grid>
                </Grid>
            </Grid>

            <!-- ============ STATUS BAR ============ -->
            <Border Grid.Row="2" Background="{DynamicResource BgPanel}"
                    BorderBrush="{DynamicResource BorderBrush}" BorderThickness="0,1,0,0"
                    CornerRadius="0,0,10,10" Padding="14,8">
                <TextBlock Text="{Binding StatusMessage}" Foreground="{DynamicResource TextMutedBrush}"
                           FontSize="11" TextTrimming="CharacterEllipsis"/>
            </Border>

        </Grid>
    </Border>

</Window>
